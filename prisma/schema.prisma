generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                Int                @id @default(autoincrement())
  title             String             @db.VarChar(255)
  description       String?
  imageUrl          String?            @map("image_url") @db.VarChar(500)
  imageUrls         String[]           @default([]) @map("image_urls")
  prepTime          String?            @map("prep_time") @db.VarChar(50)
  cookTime          String?            @map("cook_time") @db.VarChar(50)
  totalTime         String?            @map("total_time") @db.VarChar(50)
  servings          Int?
  difficulty        String?            @db.VarChar(50)
  rating            Decimal?           @db.Decimal(2, 1)
  reviews           Int                @default(0)
  likes             Int                @default(0)
  saves             Int                @default(0)
  tags              String[]           @default([])
  recipeIngredients RecipeIngredient[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@map("recipes")
}

model Ingredient {
  id                Int                @id @default(autoincrement())
  name              String             @unique @db.VarChar(255)
  imageUrl          String?            @map("image_url") @db.VarChar(500)
  category          String?            @db.VarChar(100)
  price             Decimal?           @db.Decimal(10, 2)
  recipeIngredients RecipeIngredient[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@map("ingredients")
}

model RecipeIngredient {
  id              Int                    @id @default(autoincrement())
  recipeId        Int                    @map("recipe_id")
  ingredientId    Int                    @map("ingredient_id")
  amount          String?                @db.VarChar(50)
  unit            String?                @db.VarChar(50)
  displayQuantity String?                @map("display_quantity") @db.VarChar(100)
  pantryStatus    RecipeIngredientStatus @default(MISSING) @map("pantry_status")
  note            String?
  sortOrder       Int                    @default(0) @map("sort_order")
  recipe          Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient      Ingredient             @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@unique([recipeId, ingredientId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

enum RecipeIngredientStatus {
  HAVE_ALL
  HAVE_SOME
  MISSING
}
